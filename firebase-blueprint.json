{
  "entities": {
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "Sensitive global system settings",
      "type": "object",
      "properties": {
        "paystackPublicKey": { "type": "string" },
        "paystackSecretKey": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "System user with roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "cashier"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Item available for sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stockLevel": { "type": "integer" },
        "barcode": { "type": "string" },
        "lowStockThreshold": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stockLevel"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Purchasing customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "loyaltyPoints": { "type": "integer" }
      },
      "required": ["name", "email"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "cashierId": { "type": "string" },
        "customerId": { "type": "string" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "mobile_money", "card"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "items": { "type": "array" }
      },
      "required": ["date", "cashierId", "totalAmount", "paymentMethod"]
    },
    "PaymentRequest": {
      "title": "PaymentRequest",
      "description": "Pending external payment requests",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "saleId": { "type": "string" },
        "provider": { "type": "string", "enum": ["paystack", "flutterwave"] },
        "reference": { "type": "string" },
        "status": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product vendors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "Stock replenishment orders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "received", "cancelled"] },
        "totalAmount": { "type": "number" },
        "items": { "type": "array" }
      },
      "required": ["supplierId", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer database"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Transaction history"
    },
    "/paymentRequests/{requestId}": {
      "schema": "PaymentRequest",
      "description": "Tracking external payment statuses"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Supplier database"
    },
    "/purchaseOrders/{orderId}": {
      "schema": "PurchaseOrder",
      "description": "Purchase order records"
    },
    "/config/system": {
      "schema": "SystemConfig",
      "description": "Global system configurations including sensitive API keys"
    }
  }
}
